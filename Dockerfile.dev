# Backend dev image with air hot-reload
# Source code is mounted via docker-compose volume; air watches for changes and rebuilds.

FROM golang:1.26.1-alpine

ENV GO111MODULE=on CGO_ENABLED=0 GOEXPERIMENT=greenteagc

RUN apk add --no-cache git && \
    go install github.com/air-verse/air@latest

WORKDIR /app

# Pre-download deps so they are cached in the image layer.
# Actual source is mounted at runtime via volume.
COPY go.mod go.sum ./
RUN go mod download

# Placeholder dist dirs so the embed directive compiles without real frontend files.
RUN mkdir -p web/default/dist web/classic/dist && \
    echo '<!doctype html><html><head><title>dev</title></head><body>backend hot-reload active</body></html>' > web/default/dist/index.html && \
    echo '<!doctype html><html><head><title>dev</title></head><body>backend hot-reload active</body></html>' > web/classic/dist/index.html

EXPOSE 3000
ENTRYPOINT ["air", "-c", ".air.toml"]
